<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TracerStudy" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/action_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_brand</item>
        <item name="colorSecondary">@color/accent_primary</item>
        <item name="colorOnSecondary">@color/text_on_accent</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/status_error</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/brand_primary_dark</item>
        <item name="android:navigationBarColor">@color/surface_card</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:editTextStyle">@style/Widget.TracerStudy.EditText</item>
        <item name="editTextStyle">@style/Widget.TracerStudy.EditText</item>
        <item name="materialButtonStyle">@style/Widget.TracerStudy.Button</item>
        <item name="textInputStyle">@style/Widget.TracerStudy.TextInputLayout</item>
    </style>

    <style name="Widget.TracerStudy.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="Widget.TracerStudy.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/action_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/action_primary</item>
    </style>

    <style name="Widget.TracerStudy.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_card</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_input</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_input</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_input</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_input</item>
        <item name="boxStrokeColor">@color/text_input_stroke</item>
        <item name="boxStrokeErrorColor">@color/status_error</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="startIconTint">@color/icon_primary</item>
        <item name="endIconTint">@color/icon_primary</item>
    </style>

    <style name="Widget.TracerStudy.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:fontFamily">sans</item>
    </style>
</resources>
