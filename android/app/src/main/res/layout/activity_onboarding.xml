<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:orientation="vertical"
    android:padding="20dp">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/onboardingPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:id="@+id/dotContainer"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:gravity="center"
        android:orientation="horizontal" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOnboardingNext"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="@dimen/space_md"
        android:backgroundTint="@color/action_primary"
        android:text="Lanjut"
        android:textColor="@color/text_on_brand" />

    <TextView
        android:id="@+id/tvOnboardingLogin"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="Sudah punya akun? Masuk"
        android:textColor="@color/link_primary"
        android:textStyle="bold" />
</LinearLayout>
