<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_logo_circle"
                android:gravity="center"
                android:text="FT"
                android:textColor="@color/action_primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:layout_weight="1"
                android:maxLines="2"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/homeBell"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/notifications"
                    android:src="@drawable/ic_notifications" />

                <TextView
                    android:id="@+id/tvUnreadBadge"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/bg_badge_gold"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@color/status_warning"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_brand_gradient"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <TextView
                android:id="@+id/tvHomeGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Halo!"
                android:textColor="@color/text_on_brand"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHomeMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:alpha="0.82"
                android:text="Data alumni belum tersedia"
                android:textColor="@color/text_on_brand"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTracerStatus"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/bg_badge_gold"
                android:gravity="center"
                android:paddingStart="@dimen/space_md"
                android:paddingEnd="@dimen/space_md"
                android:text="Tracer Study: Belum Diisi"
                android:textColor="@color/status_warning"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="Aksi Cepat"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="true">

            <TextView
                android:id="@+id/cardTracer"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_brand_gradient"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:padding="@dimen/space_md"
                android:text="Isi Tracer Study"
                android:textColor="@color/text_on_brand"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cardProfile"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:padding="@dimen/space_md"
                android:text="Lihat Profil"
                android:textColor="@color/action_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cardHistory"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:padding="@dimen/space_md"
                android:text="Riwayat Pengisian"
                android:textColor="@color/action_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cardContact"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:padding="@dimen/space_md"
                android:text="Hubungi Kami"
                android:textColor="@color/action_primary"
                android:textStyle="bold" />

        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="Informasi"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_info_open"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:text="Data kamu membantu peningkatan kurikulum dan akreditasi program studi."
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
