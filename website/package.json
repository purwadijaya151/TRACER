{
  "name": "tracerstudy-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:3002": "node scripts/run-dev.mjs --port 3002",
    "dev:check": "node scripts/run-dev.mjs --dry-run",
    "dev:clean": "node scripts/run-dev.mjs --clean",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean:next": "node scripts/clean-next-cache.mjs",
    "clean:next:all": "node scripts/clean-next-cache.mjs --all",
    "clean:next:inactive": "node scripts/clean-next-cache.mjs --all --keep .next-dev-3002",
    "seed:admin": "node scripts/create-admin.mjs",
    "seed:questions": "node scripts/seed-questionnaire.mjs",
    "qa:questionnaire": "node scripts/check-questionnaire-integration.mjs",
    "supabase:link": "npx supabase link --project-ref efutimhekjhqrwmrzmew",
    "supabase:push": "npx supabase db push --include-all",
    "supabase:push:dry": "npx supabase db push --include-all --dry-run",
    "e2e:admin": "node scripts/e2e-admin-smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@headlessui/react": "^2.0.0",
    "@hookform/resolvers": "^3.3.0",
    "@supabase/ssr": "^0.1.0",
