    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.0.0",
    "jsdom": "^24.1.0",
    "playwright": "^1.59.1",
    "postcss": "^8.4.0",
    "vitest": "^2.0.0"
  }
