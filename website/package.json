    "@tanstack/react-table": "^8.11.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.400.0",
    "next": "15.5.15",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.49.0",
    "recharts": "^2.10.0",
    "sonner": "^1.4.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "xlsx-js-style": "^1.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.15",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.0",
